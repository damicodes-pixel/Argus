<group name="local,sysmon,atomic_red_team,">

  <rule id="100005" level="15">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.targetImage">lsass.exe</field>
    <description>T1003 - LSASS Access Detected (Potential Credential Dumping)</description>
    <mitre>
      <id>T1003</id>
    </mitre>
  </rule>

  <rule id="100006" level="10">
    <if_sid>61603</if_sid>
    <match>AtomicRedTeam</match>
    <description>Atomic Red Team activity detected via Sysmon</description>
  </rule>

</group>

<group name="sysmon,atomic_red_team,">
  <rule id="100020" level="12">
    <if_sid>61603</if_sid>
    <match>AtomicRedTeam|atomic-red-team|Invoke-AtomicTest</match>
    <description>Atomic Red Team: Execution detected on $(win.system.computer)</description>
  </rule>
</group>