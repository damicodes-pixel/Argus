<!-- Example -->
<group name="local,syslog,sshd,">

  <!--
  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

</group>

<group name="local,sysmon,">
  <rule id="100002" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\net\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)powershell</field>
    <description>T1033 - Net.exe spawned by PowerShell (User Discovery)</description>
    <mitre>
      <id>T1033</id>
    </mitre>
  </rule>
</group>

<rule id="100003" level="10">
  <if_group>sysmon_event1</if_group>
  <field name="win.eventdata.image" type="pcre2">(?i)\\whoami\.exe$</field>
  <field name="win.eventdata.parentImage" type="pcre2">(?i)powershell</field>
  <description>T1033 - Whoami spawned by PowerShell (User Discovery)</description>
  <mitre>
    <id>T1033</id>
  </mitre>
</rule>

<rule id="100004" level="10">
  <if_group>sysmon_event1</if_group>
  <field name="win.eventdata.image" type="pcre2">(?i)\\WMIC\.exe$</field>
  <field name="win.eventdata.commandLine" type="pcre2">(?i)useraccount</field>
  <description>T1033 - WMIC useraccount enumeration (User Discovery)</description>
  <mitre>
    <id>T1033</id>
  </mitre>
</rule>